<mxfile host="Electron">
  <diagram name="Backend Overall Architecture" id="backend-overall-architecture">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="frame-backend" value="Cinemate Backend" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fbff;strokeColor=#6c8ebf;strokeWidth=2;fontStyle=1;fontSize=18;fontColor=#1f2937;verticalAlign=top;spacingTop=14;" vertex="1" parent="1">
          <mxGeometry x="300" y="40" width="560" height="660" as="geometry" />
        </mxCell>
        <mxCell id="node-frontend" value="Frontend&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Next.js UI Pages&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#111827;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="170" height="90" as="geometry" />
        </mxCell>
