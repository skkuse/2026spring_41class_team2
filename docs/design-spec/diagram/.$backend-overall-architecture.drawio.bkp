        <mxCell id="edge-frontend-route" value="HTTP request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#4d4d4d;fontSize=12;fontColor=#404040;" edge="1" parent="1" source="node-frontend" target="node-route-handler">
