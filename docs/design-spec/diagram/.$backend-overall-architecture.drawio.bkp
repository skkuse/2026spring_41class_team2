          <mxGeometry x="490" y="300" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="node-repository" value="Repository&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Drizzle queries&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1f5f9f;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#111827;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="490" y="480" width="180" height="90" as="geometry" />
