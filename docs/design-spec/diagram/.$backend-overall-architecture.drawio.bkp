          <mxGeometry x="930" y="300" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="node-supabase-db" value="Supabase DB&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;PostgreSQL&lt;/font&gt;" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ecfdf5;strokeColor=#2f855a;strokeWidth=2;fontSize=16;fontStyle=1;fontColor=#111827;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="930" y="470" width="180" height="120" as="geometry" />
